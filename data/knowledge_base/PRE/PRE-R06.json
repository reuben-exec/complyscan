{
  "requirement_id": "PRE-R06",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Language Assistance and Communication Access",
  "description": "The hospital must provide effective communication assistance to patients with limited language proficiency, hearing impairment, speech impairment, or cognitive disabilities. This includes access to professional interpreters, sign language interpreters, translated materials, and alternative communication aids to ensure patients can fully participate in their care decisions.",
  "business_objective": "To eliminate language and communication barriers, ensure informed consent and patient understanding, comply with non-discrimination principles, and provide equitable care to all patients regardless of communication ability.",
  "criticality": "High",
  "confidence_weight": 0.87,
