{
  "requirement_id": "PRE-R05",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Education and Communication",
  "description": "The hospital must provide patient education regarding their medical condition, treatment plan, medications, self-care instructions, and preventive measures. Education must be tailored to the patient's literacy level, language, and cultural background, and documented in the patient record.",
  "business_objective": "To empower patients to participate in their own care, improve treatment adherence, reduce readmissions, enhance health outcomes, and meet accreditation standards for patient-centered education.",
  "criticality": "High",
