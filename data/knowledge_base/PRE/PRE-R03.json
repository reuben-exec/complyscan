{
  "requirement_id": "PRE-R03",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Identification",
  "description": "The hospital must have a standardized patient identification process to ensure accurate identification of patients at every point of care. This includes using at least two unique identifiers before any procedure, medication administration, blood transfusion, or specimen collection to prevent errors and ensure patient safety.",
  "business_objective": "To prevent patient misidentification errors, ensure correct patient-procedure matching, enhance patient safety, and comply with national patient safety goals and accreditation standards.",
  "criticality": "Critical",
