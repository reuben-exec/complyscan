  "requirement_id": "PRE-R08",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Advance Directives and End-of-Life Communication",
  "description": "The hospital must respect patient autonomy regarding end-of-life decisions by facilitating advance directives, living wills, and do-not-resuscitate (DNR) orders. The hospital must have clear policies and procedures for documenting, honoring, and communicating patient preferences for end-of-life care, ensuring ethical and legal compliance.",
  "business_objective": "To uphold patient autonomy in end-of-life decisions, ensure ethical care delivery, comply with legal frameworks for advance directives, and provide compassionate communication during critical care transitions.",
  "criticality": "High",
  "confidence_weight": 0.89,
