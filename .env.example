# Environment Variables for ComplyScan
# Copy this file to .env and fill in your values
#
# For Render: set these in the Render Dashboard (Env Groups or per-service)

# Cloudflare Workers AI (required for LLM semantic analysis)
CF_API_TOKEN=your_cf_api_token_here
CF_ACCOUNT_ID=your_cf_account_id_here

# LLM model override (optional — recommended: @cf/qwen/qwen3-14b-instruct for
# better compliance audit reasoning)
# CF_LLM_MODEL=@cf/meta/llama-3.1-8b-instruct

# Optional: Override knowledge base paths
# HIC_DATA_PATH=data/knowledge_base/HIC
# PRE_DATA_PATH=data/knowledge_base/PRE
