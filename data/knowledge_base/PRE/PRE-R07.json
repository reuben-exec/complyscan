  "requirement_id": "PRE-R07",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Grievance Redressal and Complaint Management",
  "description": "The hospital must have a structured, accessible, and transparent grievance redressal mechanism that allows patients and their families to register complaints, provide feedback, and seek resolution without fear of discrimination or retaliation. The process must include timely acknowledgment, investigation, response, and documentation of all complaints.",
  "business_objective": "To demonstrate accountability, improve service quality through patient feedback, resolve disputes promptly, maintain patient trust, and comply with regulatory requirements for patient grievance handling.",
  "criticality": "High",
  "confidence_weight": 0.9,
