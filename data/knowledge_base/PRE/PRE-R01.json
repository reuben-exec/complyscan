  "requirement_id": "PRE-R01",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Rights Policy",
  "description": "The hospital must have a documented patient rights policy that is communicated to patients and their families. The policy should outline the rights of patients to respectful care, information, privacy, informed consent, and grievance redressal in a manner consistent with national and international standards.",
  "business_objective": "To ensure patients are aware of their rights and can exercise them, fostering trust, transparency, and patient-centered care while meeting accreditation and regulatory expectations.",
  "criticality": "Critical",
  "confidence_weight": 0.92,
