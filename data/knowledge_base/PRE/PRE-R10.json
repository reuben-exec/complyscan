  "requirement_id": "PRE-R10",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Safety Education and Participation",
  "description": "The hospital must educate patients and their families about patient safety practices, including fall prevention, medication safety, infection prevention, hand hygiene, and the importance of speaking up about concerns. Patients must be encouraged to actively participate in their own safety through clear communication and accessible safety information.",
  "business_objective": "To reduce preventable harm by engaging patients as partners in safety, improve safety culture, decrease adverse events, and align with international patient safety goals and accreditation requirements.",
  "criticality": "High",
  "confidence_weight": 0.88,
