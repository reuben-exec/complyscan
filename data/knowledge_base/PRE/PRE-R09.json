{
  "requirement_id": "PRE-R09",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Discharge Counselling and Planning",
  "description": "The hospital must provide structured discharge counselling to patients and their caregivers, ensuring they understand post-discharge care instructions, medications, follow-up appointments, warning signs, and available community resources. Discharge planning must begin early in the hospital stay and be documented comprehensively.",
  "business_objective": "To reduce preventable readmissions, ensure continuity of care, improve patient outcomes, enhance patient and caregiver preparedness, and meet accreditation standards for discharge processes.",
  "criticality": "High",
  "confidence_weight": 0.9,
