{
  "requirement_id": "PRE-R11",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Information Leaflets and Educational Materials",
  "description": "The hospital must develop, maintain, and distribute accurate, culturally appropriate, and easily understandable patient information leaflets and educational materials covering common conditions, procedures, medications, and self-care instructions. Materials must be reviewed for medical accuracy and updated regularly.",
  "business_objective": "To support informed decision-making, enhance patient understanding of health conditions and treatments, promote self-management, reduce anxiety, and ensure consistent messaging across the organization.",
  "criticality": "Medium",
  "confidence_weight": 0.82,
