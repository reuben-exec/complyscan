{
  "requirement_id": "PRE-R02",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Informed Consent",
  "description": "The hospital must ensure that informed consent is obtained from patients or their legally authorized representatives before any procedure, treatment, or intervention. Consent must be voluntary, based on adequate information about risks, benefits, alternatives, and consequences, and documented in a language the patient understands.",
  "business_objective": "To protect patient autonomy, ensure legal and ethical compliance, and demonstrate respect for patient decision-making while mitigating medico-legal risk.",
  "criticality": "Critical",
  "confidence_weight": 0.95,
