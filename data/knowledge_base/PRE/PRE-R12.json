  "requirement_id": "PRE-R12",
  "chapter": "PRE",
  "chapter_name": "Patient Rights & Education",
  "title": "Patient Responsibilities and Care Partnership",
  "description": "The hospital must inform patients and their families of their responsibilities in the healthcare process, including providing accurate medical history, following the prescribed treatment plan, respecting hospital rules and other patients' rights, and participating actively in their care. The hospital must document patient acknowledgment of these responsibilities and foster a partnership model of care.",
  "business_objective": "To promote shared accountability in healthcare, improve treatment adherence, enhance patient safety through active participation, maintain orderly care environments, and align with national patient rights frameworks that explicitly define patient responsibilities.",
  "criticality": "Medium",
